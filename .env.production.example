# Backend runtime environment for the C++ server.
# Copy values into ECS task environment/secrets, not into a committed real env file.

# RDS PostgreSQL
POSTGRES_HOST=your-rds-endpoint.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=webdb
POSTGRES_USER=webuser
POSTGRES_PASSWORD=replace-with-secret-manager-value

# JWT
JWT_SECRET=replace-with-long-random-secret
JWT_ISSUER=webserver
JWT_EXPIRES_SECONDS=3600

# S3-compatible object storage.
# The backend prefers S3_* names and still accepts legacy MINIO_* fallbacks.
S3_ENDPOINT=https://s3.ap-southeast-2.amazonaws.com
S3_PUBLIC_ENDPOINT=https://your-bucket.s3.ap-southeast-2.amazonaws.com
S3_BUCKET=your-bucket
S3_ACCESS_KEY=replace-with-secret-manager-value
S3_SECRET_KEY=replace-with-secret-manager-value
S3_REGION=ap-southeast-2
S3_UPLOAD_URL_EXPIRES=300
S3_DOWNLOAD_URL_EXPIRES=300
S3_MAX_FILENAME_LENGTH=255
